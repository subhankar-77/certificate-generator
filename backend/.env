# ================================================================
# .env — CIEM Felicitation Backend
# ================================================================
# IMPORTANT: Do NOT commit this file to GitHub.
#            Add .env to your .gitignore.
# ================================================================

# ── SERVER PORT ──
PORT=3000

# ── SQLITE DATABASE PATH ──
# EDIT: Set this to the full path of your .db file in SQLiteStudio.
#
# Windows example:
#   DB_PATH=C:/Users/YourName/Documents/ciem_students.db
#
# If you leave this blank, server.js will look for ciem_students.db
# in the same folder as server.js itself.
DB_PATH=D:/VS Code/ciem_felicitation/backend/felicitation.db.db
# ── CORS ORIGIN ──
# During development: * (allow all)
# After deploying: set to your actual site URL e.g. https://yourdomain.com
FRONTEND_ORIGIN=https://certificate-generator-green-delta.vercel.app/
